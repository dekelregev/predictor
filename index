  },
  {
    id:'m4',
    q:"Will the FDA approve olezarsen for severe hypertriglyceridemia and familial chylomicronemia?",
    drug:'Olezarsen',company:'Ionis / AstraZeneca',indication:'Severe hypertriglyceridemia',
