      <button class="fbtn" onclick="setSort('edge',this)">Edge size</button>
    </div>
  </div>

  <div class="stats">
    <div class="stat"><div class="stat-lbl">Pending decisions</div><div class="stat-val" id="s-count">8</div><div class="stat-sub">Apr–Dec 2026</div></div>
    <div class="stat"><div class="stat-lbl">Next PDUFA</div><div class="stat-val" id="s-next">Apr 30</div><div class="stat-sub">AXS-05 · Alzheimer's</div></div>
    <div class="stat"><div class="stat-lbl">Strong edge</div><div class="stat-val" id="s-edge">—</div><div class="stat-sub">≥12pp divergence</div></div>
    <div class="stat"><div class="stat-lbl">Analyzed</div><div class="stat-val" id="s-analyzed">0</div><div class="stat-sub">this session</div></div>
  </div>

  <div class="main">
    <div class="left">
      <div class="mlist" id="mlist"></div>
    </div>
    <div class="right">
      <div class="ap-head">
        <div class="ap-lbl">Signal analysis</div>
        <button class="analyze-btn" id="analyze-btn" onclick="runAnalysis()" disabled>Analyze ↗</button>
      </div>
      <div class="ap-body" id="ap-body">
        <div class="placeholder">Select a market from the list to see its PDUFA date, then click Analyze to get a base rate signal vs. current Kalshi odds.<br><br>Markets are sorted by upcoming PDUFA date. Edge = gap between historical FDA base rate for this drug class and current crowd pricing.</div>
      </div>
    </div>
  </div>
</div>

