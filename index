const S={filter:'all',sort:'pdufa',selected:null,analyzed:0};

function pCol(p){return p>=60?'#00e5a0':p>=40?'#ffb347':'#ff4f6b';}
function edgeSize(m){return Math.abs(m.baseRate-m.yes);}

function getCatTag(cat){
  const map={cardio:'<span class="tag tg">Cardio</span>',neuro:'<span class="tag tb">Neurology</span>',onco:'<span class="tag ta">Oncology</span>',other:'<span class="tag td">Other</span>'};
  return map[cat]||'<span class="tag td">FDA</span>';
}

function setFilter(f,el){
  S.filter=f;
  document.querySelectorAll('.filter-row .fbtn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderMarkets();
}

function setSort(s,el){
  S.sort=s;
  document.querySelectorAll('.sort-row .fbtn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderMarkets();
}

function getFiltered(){
  let ms=S.filter==='all'?[...ALL_MARKETS]:ALL_MARKETS.filter(m=>m.cat===S.filter);
  if(S.sort==='pdufa')ms.sort((a,b)=>a.pdufaTs-b.pdufaTs);
  else ms.sort((a,b)=>edgeSize(b)-edgeSize(a));
  return ms;
}

function renderMarkets(){
  const list=document.getElementById('mlist');
  const filtered=getFiltered();
  const strong=ALL_MARKETS.filter(m=>edgeSize(m)>=12).length;
  document.getElementById('s-edge').textContent=strong;
  if(!filtered.length){list.innerHTML='<div class="no-mkts">No markets match this filter</div>';return;}
  list.innerHTML=filtered.map(m=>{
    const sel=S.selected&&S.selected.id===m.id;
    const diff=m.baseRate-m.yes;
    const edgeHint=Math.abs(diff)>=12?(diff>0?'<span class="tag tg">edge YES</span>':'<span class="tag tr">edge NO</span>'):'';
    return`<div class="mcard${sel?' sel':''}" onclick="selectMarket('${m.id}')">
      <div class="mcard-q">${m.q}</div>
      <div class="mcard-row">
        <div class="tags">${getCatTag(m.cat)}<span class="pdufa-tag">PDUFA ${m.pdufa}</span>${edgeHint}</div>
        <div class="prob-wrap"><div class="prob" style="color:${pCol(m.yes)}">${m.yes}%</div><div class="prob-lbl">EST. YES</div></div>
      </div>
      <div class="bar-wrap"><div class="bar-fill" style="width:${m.yes}%;background:${pCol(m.yes)}"></div></div>
      <div class="mcard-bottom">
        <div class="vol-lbl">${m.company} · ${m.indication}</div>
        <a class="kalshi-link" href="${m.url}" target="_blank" onclick="event.stopPropagation()">Kalshi ↗</a>
      </div>
    </div>`;
  }).join('');
}

function selectMarket(id){
  S.selected=ALL_MARKETS.find(m=>m.id===id);
  renderMarkets();
  document.getElementById('analyze-btn').disabled=false;
  document.getElementById('ap-body').innerHTML=`<div class="placeholder"><span style="color:var(--text);font-weight:500">${S.selected.drug}</span><br>${S.selected.indication}<br>PDUFA: ${S.selected.pdufa}<br><br>${S.selected.note}<br><br>Click Analyze ↗ for full base rate signal.</div>`;
}

function analyze(m){
  const diff=m.baseRate-m.yes;
  const abs=Math.abs(diff);
  let edge='market looks fair';
  if(abs>=16)edge=diff>0?'strong edge YES':'strong edge NO';
  else if(abs>=10)edge=diff>0?'moderate edge YES':'moderate edge NO';
  else if(abs>=5)edge=diff>0?'slight edge YES':'slight edge NO';
  return{diff,edge};
}

function runAnalysis(){
  if(!S.selected)return;
  const btn=document.getElementById('analyze-btn');
  btn.disabled=true;btn.innerHTML='<span class="spin"></span>';
  const ap=document.getElementById('ap-body');
  ap.innerHTML='<div class="placeholder"><span class="spin"></span>&nbsp; Running base rate model...</div>';
  setTimeout(()=>{
    const m=S.selected;
    const {diff,edge}=analyze(m);
    const abs=Math.abs(diff);
    const vCls=abs<5?'vfair':diff>0?'vyes':'vno';
    const dCls=abs<5?'dn':diff>0?'dg':'dr';
    ap.innerHTML=`
      <div class="eg">
        <div class="egc"><div class="egn" style="color:${pCol(m.yes)}">${m.yes}%</div><div class="egl">Est. Kalshi</div></div>
        <div class="egc"><div class="egn ${diff===0?'eneu':diff>0?'epos':'eneg'}">${diff>0?'+':''}${diff}pp</div><div class="egl">Edge signal</div></div>
        <div class="egc"><div class="egn" style="color:${pCol(m.baseRate)}">${m.baseRate}%</div><div class="egl">Base rate</div></div>
      </div>
      <div class="verdict ${vCls}">
        <span class="dot ${dCls}"></span>
        <span class="vtxt">${edge}</span>
        <span class="conf">${m.conf} confidence</span>
      </div>
      <div class="divider"></div>
      <div class="section-title">Bull factors</div>
      <div class="factors">${m.bull.map(f=>`<div class="factor"><span class="factor-dir fup">+</span><span class="factor-txt">${f}</span></div>`).join('')}</div>
      <div class="divider"></div>
      <div class="section-title">Bear factors</div>
      <div class="factors">${m.bear.map(f=>`<div class="factor"><span class="factor-dir fdn">−</span><span class="factor-txt">${f}</span></div>`).join('')}</div>
      <div class="divider"></div>
      <div class="action-btns">
        <a class="act-btn btn-primary" href="${m.url}" target="_blank">View on Kalshi ↗</a>
        <button class="act-btn btn-secondary" onclick="deepDive()">Ask Claude for deeper analysis ↗</button>
      </div>`;
    S.analyzed++;
    document.getElementById('s-analyzed').textContent=S.analyzed;
    btn.disabled=false;btn.textContent='Re-analyze ↗';
  },500);
}

function deepDive(){
  if(!S.selected)return;
  const m=S.selected;
  const {diff,edge}=analyze(m);
  sendPrompt(`Deep dive on this upcoming FDA decision:\n\nDrug: ${m.drug} (${m.company})\nIndication: ${m.indication}\nPDUFA date: ${m.pdufa}\nEstimated Kalshi YES price: ${m.yes}%\nBase rate estimate: ${m.baseRate}%\nEdge signal: ${diff>0?'+':''}${diff}pp (${edge})\n\nBackground: ${m.note}\n\nWhat are the key factors I should research before trading this? What's the crowd most likely missing?`);
}

// Init
renderMarkets();
</script>
