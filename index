
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@700;800&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0c0f;--surface:#111418;--surface2:#181d24;--border:#1c2028;--border2:#252c38;
  --text:#dde3ec;--muted:#4e5a6e;--dim:#1e2530;--accent:#00d4ff;--green:#00e5a0;
  --red:#ff4f6b;--amber:#ffb347;--accentdim:rgba(0,212,255,0.08);
}
html,body{margin:0;padding:0;background:var(--bg)}
.app{font-family:'DM Mono',monospace;color:var(--text);background:var(--bg);display:flex;flex-direction:column}
.topbar{display:flex;justify-content:space-between;align-items:center;padding:0 20px;height:48px;border-bottom:1px solid var(--border);flex-shrink:0}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:var(--accent);letter-spacing:-0.02em}
.logo-sep{width:1px;height:14px;background:var(--border2)}
.logo-sub{font-size:9px;color:var(--muted);letter-spacing:0.14em;text-transform:uppercase}
.logo-badge{font-size:8px;letter-spacing:0.08em;text-transform:uppercase;padding:2px 8px;border-radius:2px;background:rgba(0,229,160,0.08);color:var(--green);border:1px solid rgba(0,229,160,0.18)}
.topbar-right{display:flex;align-items:center;gap:12px}
.pdufa-note{font-size:9px;color:var(--muted);letter-spacing:0.06em}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
.subbar{display:flex;justify-content:space-between;align-items:center;padding:0 20px;height:38px;border-bottom:1px solid var(--border);flex-shrink:0}
.filter-row{display:flex;gap:4px;align-items:center}
.filter-lbl{font-size:9px;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase;margin-right:4px}
.fbtn{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.07em;text-transform:uppercase;padding:3px 9px;border:1px solid var(--border2);border-radius:2px;background:transparent;color:var(--muted);cursor:pointer;transition:all 0.12s}
.fbtn.active{border-color:var(--accent);color:var(--accent);background:var(--accentdim)}
.fbtn:hover:not(.active){color:var(--text)}
.sort-row{display:flex;gap:4px;align-items:center}
.sort-lbl{font-size:9px;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase;margin-right:2px}
.main{display:grid;grid-template-columns:1fr 310px;flex:1}
.left{border-right:1px solid var(--border);display:flex;flex-direction:column}
.stats{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--border);flex-shrink:0}
.stat{padding:9px 14px;border-right:1px solid var(--border)}
.stat:last-child{border-right:none}
.stat-lbl{font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:2px}
.stat-val{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--text)}
.stat-sub{font-size:8px;color:var(--dim);margin-top:1px}
.mlist{flex:1}
.mcard{padding:13px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s}
.mcard:hover{background:var(--surface)}
.mcard.sel{background:var(--surface2);border-left:2px solid var(--accent);padding-left:14px}
.mcard-q{font-size:11px;color:var(--text);line-height:1.5;margin-bottom:8px}
.mcard-row{display:flex;justify-content:space-between;align-items:center;gap:8px}
.mcard-bottom{display:flex;justify-content:space-between;align-items:center;margin-top:6px}
.tags{display:flex;gap:5px;flex-wrap:wrap;align-items:center}
.tag{font-size:8px;letter-spacing:0.07em;text-transform:uppercase;padding:2px 7px;border-radius:2px;border:1px solid;white-space:nowrap}
.tg{color:#00e5a0;border-color:#0a3d2a;background:#041a12}
.ta{color:#ffb347;border-color:#5a3800;background:#1f1200}
.tb{color:#00d4ff;border-color:#003d52;background:#001922}
.tr{color:#ff4f6b;border-color:#5a1020;background:#1f0509}
.tp{color:#b794f4;border-color:#3d2a5a;background:#1a0f2a}
.td{color:var(--muted);border-color:var(--border2)}
.pdufa-tag{font-size:8px;color:var(--amber);letter-spacing:0.06em;white-space:nowrap}
.prob-wrap{display:flex;flex-direction:column;align-items:flex-end;gap:1px;flex-shrink:0}
.prob{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;white-space:nowrap;line-height:1}
.prob-lbl{font-size:7px;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted)}
.bar-wrap{margin-top:7px;height:2px;background:var(--border2);border-radius:1px}
.bar-fill{height:2px;border-radius:1px}
.vol-lbl{font-size:8px;color:var(--dim)}
.kalshi-link{font-size:8px;color:var(--muted);letter-spacing:0.05em;text-decoration:none;border:1px solid var(--border2);border-radius:2px;padding:2px 7px;transition:color 0.12s,border-color 0.12s}
.kalshi-link:hover{color:var(--accent);border-color:var(--accent)}
.no-mkts{padding:40px 16px;text-align:center;font-size:10px;color:var(--muted);letter-spacing:0.06em;line-height:2.2}
.right{display:flex;flex-direction:column;background:var(--surface)}
.ap-head{display:flex;justify-content:space-between;align-items:center;padding:10px 16px;border-bottom:1px solid var(--border);flex-shrink:0}
.ap-lbl{font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted)}
.analyze-btn{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;padding:5px 12px;border:1px solid var(--accent);border-radius:3px;background:transparent;color:var(--accent);cursor:pointer;transition:background 0.12s}
.analyze-btn:hover{background:var(--accentdim)}
.analyze-btn:disabled{opacity:0.3;cursor:not-allowed;border-color:var(--muted);color:var(--muted)}
.ap-body{padding:14px;overflow-y:auto;flex:1}
.placeholder{font-size:10px;color:var(--muted);line-height:1.9}
.eg{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border-radius:5px;overflow:hidden;margin-bottom:12px}
.egc{background:var(--surface2);padding:11px 6px;text-align:center}
.egn{font-family:'Syne',sans-serif;font-size:20px;font-weight:700}
.egl{font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-top:2px}
.epos{color:var(--accent)}.eneg{color:var(--red)}.eneu{color:var(--muted)}
.verdict{display:flex;align-items:center;gap:7px;padding:8px 10px;border-radius:4px;margin-bottom:12px;border:1px solid}
.vyes{background:rgba(0,229,160,0.05);border-color:rgba(0,229,160,0.2);color:var(--green)}
.vno{background:rgba(255,79,107,0.05);border-color:rgba(255,79,107,0.2);color:var(--red)}
.vfair{background:var(--dim);border-color:var(--border2);color:var(--muted)}
.vtxt{font-size:10px;letter-spacing:0.06em;text-transform:uppercase;flex:1}
.conf{font-size:8px;letter-spacing:0.08em;text-transform:uppercase;padding:2px 6px;border-radius:2px;background:var(--dim);color:var(--muted)}
.dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.dg{background:var(--green)}.dr{background:var(--red)}.dn{background:var(--muted)}
.section-title{font-size:8px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:7px;opacity:0.6}
.factors{display:flex;flex-direction:column;gap:7px;margin-bottom:14px}
.factor{display:flex;align-items:baseline;gap:7px;font-size:10px}
.factor-dir{font-family:'Syne',sans-serif;font-weight:700;font-size:11px;min-width:10px;flex-shrink:0}
.fup{color:var(--green)}.fdn{color:var(--red)}
.factor-txt{color:var(--muted);line-height:1.55}
.divider{height:1px;background:var(--border);margin:12px 0}
.action-btns{display:flex;flex-direction:column;gap:6px;margin-top:4px}
.act-btn{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.08em;text-transform:uppercase;padding:7px 12px;border-radius:3px;cursor:pointer;transition:all 0.12s;text-align:center;text-decoration:none;display:block;width:100%}
.btn-primary{border:1px solid var(--accent);background:var(--accentdim);color:var(--accent)}
.btn-primary:hover{background:rgba(0,212,255,0.15)}
.btn-secondary{border:1px solid var(--border2);background:transparent;color:var(--muted)}
.btn-secondary:hover{border-color:var(--accent);color:var(--accent)}
.nevada-banner{background:rgba(255,79,107,0.07);border-bottom:1px solid rgba(255,79,107,0.2);padding:7px 20px;font-size:9px;color:var(--red);letter-spacing:0.04em;display:flex;align-items:center;gap:8px;flex-shrink:0}
.spin{display:inline-block;width:9px;height:9px;border:1.5px solid var(--dim);border-top-color:var(--accent);border-radius:50%;animation:spin 0.7s linear infinite;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}
</style>

<h2 style="position:absolute;left:-9999px">EDGE — FDA PDUFA calendar and signal analyzer</h2>

<div class="app">
  <div class="topbar">
    <div class="logo">
      <div class="logo-mark">EDGE/</div>
      <div class="logo-sep"></div>
      <div class="logo-sub">FDA approval signal</div>
      <div class="logo-badge">Kalshi · CFTC regulated</div>
    </div>
    <div class="topbar-right">
      <div class="pdufa-note">Real PDUFA calendar · Apr–Dec 2026</div>
      <div class="live-dot"></div>
    </div>
  </div>

  <div class="nevada-banner">
    <span>⚠</span>
    <span>Nevada trading blocked by court injunction (extended Apr 17). 9th Circuit hearing ongoing. Tool ready for when access restores.</span>
  </div>

  <div class="subbar">
    <div class="filter-row">
      <div class="filter-lbl">Category</div>
      <button class="fbtn active" onclick="setFilter('all',this)">All</button>
      <button class="fbtn" onclick="setFilter('cardio',this)">Cardio</button>
